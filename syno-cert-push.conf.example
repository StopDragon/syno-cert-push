# syno-cert-push.conf  -- place at /etc/syno-cert-push.conf, mode 600
# chmod 600 /etc/syno-cert-push.conf

# NPM (Docker) Let's Encrypt 'live' directory -- the path as seen on the HOST.
# The standard NPM compose layout keeps letsencrypt on its own /etc/letsencrypt volume:
#     volumes:  - ./letsencrypt:/etc/letsencrypt
#   -> host path e.g. /opt/npm/letsencrypt/live
# Some setups keep it under /data -> /opt/npm/data/letsencrypt/live
# Find it with:
#   docker inspect <npm_container> --format '{{range .Mounts}}{{.Source}} -> {{.Destination}}{{"\n"}}{{end}}'
NPM_LIVE_DIR=/opt/npm/letsencrypt/live

# The (single) domain whose certificate should be pushed to Synology
DRIVE_DOMAIN=drive.example.com

# Synology DSM, reachable from this host (internal IP is fine)
SYNO_SCHEME=https
SYNO_HOST=192.168.1.10
SYNO_PORT=5001
SYNO_INSECURE=1          # internal-IP https has a CN mismatch -> keep 1

# An account in the 'administrators' group (a dedicated user is recommended)
SYNO_USER=acme
SYNO_PASS=changeme

# The 'description' shown in DSM > Security > Certificate for the cert to replace.
# The cert with this description is replaced in place (service mapping is kept).
SYNO_CERT_DESC=drive.example.com
SYNO_CREATE=0            # set 1 to create a new cert if none matches

# Runtime state (device_id, last hash)
STATE_DIR=/var/lib/syno-cert-push
DEVICE_NAME=CertRenewal
